@page
@model сайт_курсач.Pages.Masters.IndexModel

@{
    ViewData["Title"] = "Мастера";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h1 class="page-title">
        Мастера
    </h1>

    <a asp-page="Create"
       class="btn custom-add-btn">

        + Добавить мастера

    </a>

</div>

<div class="custom-table">

    <table class="table align-middle">

        <thead>

            <tr>

                <th>
                    Имя
                </th>

                <th>
                    Специализация
                </th>

                <th>
                    Действия
                </th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model.Masters)
            {
                <tr>

                    <td>
                        @item.FirstName
                    </td>

                    <td>
                        @item.Specialization
                    </td>

                    <td>

                        <a asp-page="./Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-sm action-edit">

                            Изменить

                        </a>

                        <a asp-page="./Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-sm action-delete">

                            Удалить

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>