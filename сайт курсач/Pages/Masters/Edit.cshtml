@page "{id:int}"

@model сайт_курсач.Pages.Masters.EditModel

@{
    ViewData["Title"] = "Изменить мастера";
}

<div class="form-container">

    <h1 class="page-title mb-4">

        Изменить мастера

    </h1>

    <form method="post">

        <input type="hidden"
               asp-for="Master.Id" />

        <div class="mb-4">

            <label asp-for="Master.FirstName"
                   class="form-label">

                Имя

            </label>

            <input asp-for="Master.FirstName"
                   class="form-control custom-input" />

        </div>

        <div class="mb-4">

            <label asp-for="Master.Specialization"
                   class="form-label">

                Специализация

            </label>

            <input asp-for="Master.Specialization"
                   class="form-control custom-input" />

        </div>

        <button type="submit"
                class="btn custom-save-btn">

            Сохранить

        </button>

        <a asp-page="Index"
           class="btn custom-cancel-btn">

            Назад

        </a>

    </form>

</div>