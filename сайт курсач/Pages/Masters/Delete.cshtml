@page "{id:int}"

@model сайт_курсач.Pages.Masters.DeleteModel

@{
    ViewData["Title"] = "Удаление мастера";
}

<div class="form-container text-center">

    <h1 class="page-title mb-4">

        Удаление мастера

    </h1>

    <h4 class="mb-4">

        Вы уверены, что хотите удалить мастера:

        <strong>

            @Model.Master.FirstName

        </strong>

        ?

    </h4>

    <form method="post">

        <input type="hidden"
               asp-for="Master.Id" />

        <button type="submit"
                class="btn action-delete">

            Удалить

        </button>

        <a asp-page="Index"
           class="btn custom-cancel-btn">

            Отмена

        </a>

    </form>

</div>