@page "{id:int}"

@model сайт_курсач.Pages.Clients.DeleteModel

@{
    ViewData["Title"] = "Удаление клиента";
}

<div class="form-container text-center">

    <h1 class="page-title mb-4">

        Удаление клиента

    </h1>

    <h4 class="mb-4">

        Вы уверены, что хотите удалить клиента:

        <strong>

            @Model.Client.FirstName

        </strong>

        ?

    </h4>

    <form method="post">

        <input type="hidden"
               asp-for="Client.Id" />

        <button type="submit"
                class="btn action-delete">

            Удалить

        </button>

        <a asp-page="Index"
           class="btn custom-cancel-btn">

            Отмена

        </a>

    </form>

</div>