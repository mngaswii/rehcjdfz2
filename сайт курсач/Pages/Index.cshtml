@page
@model IndexModel

@{
    ViewData["Title"] = "Главная";
}

<div class="hero-section">

    <div class="container">

        <div class="hero-content">

            <h1 class="hero-title">
                LOFT Beauty
            </h1>

            <p class="hero-subtitle">
                CRM система салона красоты
            </p>

            <a asp-page="/Appointments/Create"
               class="btn hero-button">

                Записаться онлайн

            </a>

        </div>

    </div>

</div>

<div class="container mt-5">

    <h2 class="section-title mb-4">
        Наши услуги
    </h2>

    <div class="row">

        <div class="col-md-4">

            <div class="service-card">

                <h3>
                    Маникюр
                </h3>

                <p>
                    Уход за ногтями и дизайн.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="service-card">

                <h3>
                    Стрижка
                </h3>

                <p>
                    Женские и мужские стрижки.
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="service-card">

                <h3>
                    Окрашивание
                </h3>

                <p>
                    Современные техники окрашивания.
                </p>

            </div>

        </div>

    </div>

</div>

<div class="container mt-5 mb-5">

    <h2 class="section-title mb-4">
        CRM статистика
    </h2>

    <div class="row">

        <div class="col-md-4">

            <div class="stats-card">

                <h3>
                    Клиенты
                </h3>

                <p class="stats-number">
                    120+
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="stats-card">

                <h3>
                    Мастера
                </h3>

                <p class="stats-number">
                    8
                </p>

            </div>

        </div>

        <div class="col-md-4">

            <div class="stats-card">

                <h3>
                    Записи
                </h3>

                <p class="stats-number">
                    350+
                </p>

            </div>

        </div>

    </div>

</div>