@page
@model IndexModel

@{
    ViewData["Title"] = "Главная";
}

<div class="hero-section text-center">

    <div class="hero-content">

        <h1 class="display-3 fw-bold">
            LOFT Beauty
        </h1>

        <p class="lead mt-3">
            Современный салон красоты в вашем городе
        </p>

        <p>
            Маникюр • Педикюр • Окрашивание • Стрижки • Укладки
        </p>

        <div class="mt-4">

            <a asp-page="/Booking/Create"
               class="btn btn-primary btn-lg">

                Записаться онлайн

            </a>

        </div>

    </div>

</div>

<div class="text-center my-5">

    <img src="~/images/salon.jpg"
         alt="LOFT Beauty"
         class="img-fluid rounded shadow"
         style="max-width:800px; width:100%; height:350px; object-fit:cover;" />

</div>

<div class="row text-center g-4">

    <div class="col-md-4">

        <div class="card h-100 shadow-sm border-0">

            <img src="~/images/services.jpg"
                 class="card-img-top"
                 style="height:180px; object-fit:cover;"
                 alt="Услуги">

            <div class="card-body">

                <h3>Услуги</h3>

                <p>
                    Широкий выбор услуг красоты для женщин и мужчин.
                </p>

                <a asp-page="/Services/Index"
                   class="btn btn-outline-dark">

                    Смотреть услуги

                </a>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card h-100 shadow-sm border-0">

            <img src="~/images/masters.jpg"
                 class="card-img-top"
                 style="height:180px; object-fit:cover;"
                 alt="Мастера">

            <div class="card-body">

                <h3>Мастера</h3>

                <p>
                    Профессиональные специалисты с опытом работы.
                </p>

                <a asp-page="/Masters/Index"
                   class="btn btn-outline-dark">

                    Наши мастера

                </a>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card h-100 shadow-sm border-0">

            <img src="~/images/booking.jpg"
                 class="card-img-top"
                 style="height:180px; object-fit:cover;"
                 alt="Онлайн запись">

            <div class="card-body">

                <h3>Онлайн запись</h3>

                <p>
                    Выберите услугу, мастера и удобное время.
                </p>

                <a asp-page="/Booking/Create"
                   class="btn btn-outline-dark">

                    Записаться

                </a>

            </div>

        </div>

    </div>

</div>

<div class="mt-5 p-4 bg-light rounded shadow-sm">

    <h2>Почему выбирают нас?</h2>

    <ul class="mt-3">
        <li>Квалифицированные мастера</li>
        <li>Современное оборудование</li>
        <li>Удобная онлайн запись</li>
        <li>Индивидуальный подход к каждому клиенту</li>
    </ul>

</div>

<div class="mt-5 text-center">

    <h2>Контакты</h2>

    <p>г. Санкт-Петербург</p>

    <p>+7 (967) 555-33-52</p>

    <p>loftbeauty@mail.com</p>

</div>