@page "{id:int}"

@model сайт_курсач.Pages.Appointments.DeleteModel

@{
    ViewData["Title"] = "Удаление записи";
}

<div class="form-container text-center">

    <h1 class="page-title mb-4">

        Удаление записи

    </h1>

    <h4 class="mb-4">

        Удалить запись?

    </h4>

    <form method="post">

        <input type="hidden"
               asp-for="Appointment.Id" />

        <button type="submit"
                class="btn action-delete">

            Удалить

        </button>

        <a asp-page="Index"
           class="btn custom-cancel-btn">

            Отмена

        </a>

    </form>

</div>