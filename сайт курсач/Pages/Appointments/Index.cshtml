@page
@model сайт_курсач.Pages.Appointments.IndexModel

@{
    ViewData["Title"] = "Записи";
}

<div class="d-flex justify-content-between align-items-center mb-4">

    <h1 class="page-title">
        Записи
    </h1>

    <a asp-page="Create"
       class="btn custom-add-btn">

        + Новая запись

    </a>

</div>

<div class="custom-table">

    <table class="table align-middle">

        <thead>

            <tr>

                <th>ID</th>

                <th>Клиент</th>

                <th>Мастер</th>

                <th>Услуга</th>

                <th>Дата</th>

                <th>Действия</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model.Appointments)
            {
                <tr>

                    <td>
                        @item.Id
                    </td>

                    <td>
                        @item.Client.FirstName @item.Client.LastName
                    </td>

                    <td>
                        @item.Master.FirstName @item.Master.LastName
                    </td>

                    <td>
                        @item.Service.Name
                    </td>

                    <td>
                        @item.AppointmentDate.ToString("dd.MM.yyyy HH:mm")
                    </td>

                    <td>

                        <a asp-page="./Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-sm action-edit">

                            Изменить

                        </a>

                        <a asp-page="./Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-sm action-delete">

                            Удалить

                        </a>

                        <a asp-page="/Payments/FakePayment"
                           asp-route-appointmentId="@item.Id"
                           class="btn btn-sm btn-success">

                            Оплатить

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>