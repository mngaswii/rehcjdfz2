@using Microsoft.AspNetCore.Http

@{
    string currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - LOFT Beauty</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/сайт_курсач.styles.css"
          asp-append-version="true" />
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container">

            <a class="navbar-brand"
               asp-page="/Index">
                LOFT Beauty
            </a>

            <div class="collapse navbar-collapse">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-page="/Index">
                            Главная
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-page="/Services/Index">
                            Услуги
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-page="/Masters/Index">
                            Мастера
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-page="/Booking/Create">
                            Онлайн запись
                        </a>
                    </li>

                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-page="/Clients/Index">
                                Клиенты
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-page="/Appointments/Index">
                                Записи
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-page="/Payments/Index">
                                Платежи
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-page="/Reports/Index">
                                Отчёты
                            </a>
                        </li>
                    }

                </ul>

                <ul class="navbar-nav">

                    @if (Context.Session.GetString("UserLogin") == null)
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-page="/Account/Login">
                                Вход
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <span class="nav-link">
                                @Context.Session.GetString("UserLogin")
                            </span>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-page="/Account/Logout">
                                Выход
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <div class="container mt-4">

        <main role="main">

            @RenderBody()

        </main>

    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container">
            © 2026 LOFT Beauty
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>