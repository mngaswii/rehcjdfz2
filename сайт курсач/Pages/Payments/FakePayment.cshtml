@page
@model сайт_курсач.Pages.Payments.FakePaymentModel

@{
    ViewData["Title"] = "Подтверждение оплаты";
}

<div class="container">

    <div class="card shadow-lg p-4 mt-5">

        <h2 class="mb-4 text-center">
            Подтверждение оплаты
        </h2>

        <p>
            <strong>Номер записи:</strong>
            @Model.AppointmentId
        </p>

        <p>
            <strong>Стоимость услуги:</strong>
            @Model.Amount ₽
        </p>

        <p class="text-muted">
            Для учебного проекта используется имитация оплаты.
        </p>

        <form method="post">

            <input type="hidden"
                   asp-for="AppointmentId" />

            <button type="submit"
                    class="btn btn-success w-100">

                Подтвердить оплату

            </button>

        </form>

    </div>

</div>