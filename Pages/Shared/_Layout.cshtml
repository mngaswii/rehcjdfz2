@using Microsoft.AspNetCore.Http

<!DOCTYPE html>

@{
    string currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}

<html lang="ru">

<head>
    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - LOFT Beauty
    </title>

    <script type="importmap"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/сайт_курсач.styles.css"
          asp-append-version="true" />

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg custom-navbar">

            <div class="container">

                <a class="navbar-brand logo-text"
                   asp-page="/Index">

                    LOFT Beauty

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="navbarContent">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">

                            <a class="nav-link @(currentPage == "/Index" ? "active-link" : "")"
                               asp-page="/Index">

                                Главная

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(currentPage.Contains("/Services") ? "active-link" : "")"
                               asp-page="/Services/Index">

                                Услуги

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(currentPage.Contains("/Clients") ? "active-link" : "")"
                               asp-page="/Clients/Index">

                                Клиенты

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(currentPage.Contains("/Masters") ? "active-link" : "")"
                               asp-page="/Masters/Index">

                                Мастера

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(currentPage.Contains("/Appointments") ? "active-link" : "")"
                               asp-page="/Appointments/Index">

                                Записи

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link @(currentPage.Contains("/Reports") ? "active-link" : "")"
                               asp-page="/Reports/Index">

                                Отчёты

                            </a>

                        </li>

                    </ul>

                    <ul class="navbar-nav">

                        @if (Context.Session.GetString("UserLogin") == null)
                        {
                            <li class="nav-item">

                                <a class="nav-link login-link"
                                   asp-page="/Account/Login">

                                    Вход

                                </a>

                            </li>
                        }
                        else
                        {
                            <li class="nav-item">

                                <span class="nav-link user-name">

                                    @Context.Session.GetString("UserLogin")

                                </span>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link logout-link"
                                   asp-page="/Account/Logout">

                                    Выход

                                </a>

                            </li>
                        }

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container">

        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>

    <footer class="footer-custom mt-5">

        <div class="container">

            © 2026 LOFT Beauty CRM

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>