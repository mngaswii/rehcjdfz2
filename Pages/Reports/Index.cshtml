@page
@model сайт_курсач.Pages.Reports.IndexModel

@{
    ViewData["Title"] = "Отчёты";
}

<h1 class="page-title mb-5">
    CRM Отчёты
</h1>

<div class="row">

    <div class="col-md-3">

        <div class="stats-card">

            <h3>
                Клиенты
            </h3>

            <p class="stats-number">
                @Model.ClientsCount
            </p>

        </div>

    </div>

    <div class="col-md-3">

        <div class="stats-card">

            <h3>
                Мастера
            </h3>

            <p class="stats-number">
                @Model.MastersCount
            </p>

        </div>

    </div>

    <div class="col-md-3">

        <div class="stats-card">

            <h3>
                Услуги
            </h3>

            <p class="stats-number">
                @Model.ServicesCount
            </p>

        </div>

    </div>

    <div class="col-md-3">

        <div class="stats-card">

            <h3>
                Записи
            </h3>

            <p class="stats-number">
                @Model.AppointmentsCount
            </p>

        </div>

    </div>

</div>